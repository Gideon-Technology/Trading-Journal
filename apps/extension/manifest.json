{
  "manifest_version": 3,
  "name": "G-Trade",
  "description": "G-Trade — Professional Forex Trading Journal. Log trades while your broker is open.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FX Journal",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
